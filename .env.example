# Copia como .env en la raíz (no subir .env a Git).

# APIs externas (solo servidor)
NINJA_API_KEY=
NINJAS_API_KEY=
UNSPLASH_ACCESS_KEY=

# Seguridad: clave que el frontend envía en X-API-KEY (misma en localStorage del navegador)
API_SECRET_KEY=

# CORS: orígenes permitidos separados por coma (URL pública del frontend en producción)
ORIGEN_PERMITIDO=http://localhost:8080,http://127.0.0.1:8080

# Servidor
HOST=0.0.0.0
PORT=8000
